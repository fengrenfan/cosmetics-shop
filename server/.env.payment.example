# 支付模式：mock | sandbox | prod
PAY_MODE=mock

# 公共
PAY_GATEWAY_TIMEOUT_MS=8000

# 微信（小程序/H5）
PAY_WECHAT_MCH_ID=your_wechat_mchid
PAY_WECHAT_MINIAPP_APP_ID=your_wechat_miniapp_appid
PAY_WECHAT_H5_APP_ID=your_wechat_h5_appid
PAY_WECHAT_NOTIFY_URL=https://your.domain/api/payment/notify/wechat
PAY_WECHAT_RETURN_URL=https://your.h5.return/wechat
PAY_WECHAT_MINIAPP_CREATE_URL=https://gateway.example/wechat/miniapp/create
PAY_WECHAT_H5_CREATE_URL=https://gateway.example/wechat/h5/create

# 支付宝（H5）
PAY_ALIPAY_MCH_ID=your_alipay_pid_or_mchid
PAY_ALIPAY_H5_APP_ID=your_alipay_appid
PAY_ALIPAY_NOTIFY_URL=https://your.domain/api/payment/notify/alipay
PAY_ALIPAY_RETURN_URL=https://your.h5.return/alipay
PAY_ALIPAY_H5_CREATE_URL=https://gateway.example/alipay/h5/create
